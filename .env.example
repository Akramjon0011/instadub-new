# Vercel yoki Render ga joylash uchun quyidagi muhit o'zgaruvchilarini (Environment Variables) sozlamalarga qo'shish kerak:

# Gemini API kaliti (Serverless API funksiyalari uchun, brauzerdan maxfiy saqlanadi)
# Olish uchun: https://aistudio.google.com/app/apikey
GCP_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
VERTEX_PROJECT=gen-lang-client-0017562692

# Firebase sozlamalari (Tizimga kirish va Data Base uchun kerak)
# Olish uchun: https://console.firebase.google.com/
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
VITE_FIREBASE_DATABASE_ID=(default)
