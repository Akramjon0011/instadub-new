rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Common Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation for User Entity
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'credits', 'role', 'plan', 'createdAt', 'updatedAt']) 
        && data.keys().size() == 6
        && data.email is string && data.email.size() > 0 && data.email.size() <= 256
        && data.credits is number
        && data.role in ['user', 'admin']
        && data.plan in ['free', 'pro', 'creator']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // Validation for DubbingHistory Entity
    function isValidHistory(data) {
      return data.keys().hasAll(['originalText', 'translatedText', 'targetLanguage', 'createdAt'])
        && data.keys().size() == 4
        && data.originalText is string && data.originalText.size() <= 10000
        && data.translatedText is string && data.translatedText.size() <= 10000
        && data.targetLanguage is string && data.targetLanguage.size() <= 100
        && data.createdAt is timestamp;
    }

    // Paths
    match /users/{userId} {
      // Admin and owner can read
      allow get: if (isOwner(userId) || request.auth.token.email == 'optimbazar@gmail.com') && isValidId(userId);
      allow list: if isOwner(userId) || request.auth.token.email == 'optimbazar@gmail.com';

      // Admin and owner can create
      allow create: if (isOwner(userId) || request.auth.token.email == 'optimbazar@gmail.com') && isValidId(userId)
        && isValidUser(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && (
          (
            incoming().role == 'user'
            && incoming().plan == 'free'
            && incoming().credits <= 5
          ) || (
            request.auth.token.email == 'optimbazar@gmail.com'
          )
        );

      allow update: if (isOwner(userId) || request.auth.token.email == 'optimbazar@gmail.com') && isValidId(userId)
        && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          (
            isOwner(userId)
            && request.auth.token.email != 'optimbazar@gmail.com'
            && incoming().email == existing().email
            && incoming().role == existing().role
            && incoming().diff(existing()).affectedKeys().hasOnly(['credits', 'plan', 'updatedAt'])
          ) || (
            request.auth.token.email == 'optimbazar@gmail.com'
          )
        );
        
      match /history/{historyId} {
        allow get: if isOwner(userId) && isValidId(userId) && isValidId(historyId);
        allow list: if isOwner(userId) && isValidId(userId);
        
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(historyId)
          && isValidHistory(incoming())
          && incoming().createdAt == request.time
          // Ensure atomicity: the user must decrement a credit to add a history item (?) Well, we can't easily do a cross-document validation for credits here without `getAfter`, but decrement happen client side for now.
          // Actually get() check against user doc is expensive but okay for a small app. We'll rely on the client update for the credit decrement.
          ;
      }
    }
  }
}
